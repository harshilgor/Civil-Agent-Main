# -----------------------------------------------------------------------------
# CivilAgent backend environment template.
# Copy to .env and override per environment. Never commit real secrets.
# -----------------------------------------------------------------------------

# Service identity
CIVILAGENT_ENV=local
PARSER_VERSION=1.0.0
SCHEMA_VERSION=parsed_geometry@1.0.0

# Postgres
DATABASE_URL=postgresql+asyncpg://civilagent:civilagent@postgres:5432/civilagent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis (used by ARQ + WebSocket pub/sub)
REDIS_URL=redis://redis:6379/0

# S3 / object store (LocalStack or AWS)
S3_ENDPOINT_URL=http://localstack:4566
S3_REGION=us-east-1
S3_BUCKET=civilagent-uploads
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_PRESIGN_TTL_SECONDS=900

# Upload constraints
MAX_UPLOAD_BYTES=524288000   # 500 MB
ALLOWED_FORMATS=ifc,dxf,dwg,pdf

# Parsing
PARSE_TIMEOUT_SECONDS=600
WORKER_MAX_JOBS=4

# IfcOpenShell — optional. Default: use the ``ifcopenshell`` from pip / venv
# (https://docs.ifcopenshell.org/ifcopenshell-python/installation.html).
# If you unpacked a platform wheel manually, set this to the folder that
# *contains* the ``ifcopenshell`` package (not the inner package path).
# Windows example:
#   CIVILAGENT_IFCOPENSHELL_EXTRAPATH=C:\Users\you\Downloads\ifcopenshell-python-0.8.5-py312-win64
#CIVILAGENT_IFCOPENSHELL_EXTRAPATH=

# Anthropic (raster PDF vision)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Auth (JWT verification)
# Production: set AUTH_JWKS_URL to your IdP's JWKS endpoint, e.g.:
#   Auth0: https://<tenant>.auth0.com/.well-known/jwks.json
#   Clerk: https://<frontend-api>/.well-known/jwks.json
# org_id is read from AUTH_JWT_ORG_CLAIM (default 'org_id'); fall back
# is the 'org' claim, then the 'azp' claim.
AUTH_JWT_AUDIENCE=civilagent
AUTH_JWT_ISSUER=https://auth.civilagent.local
AUTH_JWKS_URL=
AUTH_JWT_ORG_CLAIM=org_id
AUTH_JWT_ALGORITHMS=RS256,ES256
AUTH_JWKS_CACHE_TTL_SECONDS=900
AUTH_DEV_BYPASS=true   # local dev only — never set true in prod

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PORT=9090
